# Copie ce fichier en `.env` et remplis les valeurs. Le `.env` est git-ignoré.
# En production : ces valeurs vont dans les variables secrètes Railway, PAS dans le repo.

# ── Epidemic Sound (Pro) ──
# JWT de compte personnel (aud: epidemic-api). ATTENTION: 30 jours -> refresh OAuth requis pour une routine quotidienne.
EPIDEMIC_JWT=
EPIDEMIC_MCP_URL=https://www.epidemicsound.com/a/mcp-service/mcp

# ── YouTube Data API v3 ──
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# ── Claude Code CLI (auth cloud, comme reddit-warmup) ──
CLAUDE_CODE_OAUTH_TOKEN=

# ── Supabase (si base de données) ──
SUPABASE_ACCESS_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
APP_ENCRYPTION_KEY=
